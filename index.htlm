<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Steam Pro v25.0</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap');

        :root {
            --steam-bg: #1b2838;
            --steam-dark: #171d25;
            --steam-blue: #66c0f4;
            --steam-green: #a4d007;
            --text-main: #d1d5db;
        }

        /* ANTI-COPY & NO-SELECT */
        * { 
            margin: 0; padding: 0; box-sizing: border-box; 
            font-family: 'Inter', sans-serif;
            -webkit-user-select: none; user-select: none;
            -webkit-touch-callout: none;
            outline: none; -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--steam-dark); color: white;
            height: 100vh; display: flex; flex-direction: column; overflow: hidden;
        }

        header {
            background: var(--steam-dark); height: 55px;
            padding: 0 25px; display: flex; align-items: center; gap: 25px;
            border-bottom: 1px solid rgba(0,0,0,0.5); font-size: 14px;
        }

        .nav-link { cursor: pointer; color: #c6d4df; font-weight: 500; text-transform: uppercase; }
        .nav-link.active { color: white; border-bottom: 2px solid var(--steam-blue); }

        .header-right { margin-left: auto; display: flex; align-items: center; gap: 20px; }
        .cart-btn { background: #316282; padding: 5px 15px; border-radius: 2px; cursor: pointer; font-size: 12px; }

        .wrapper { display: flex; flex: 1; overflow: hidden; }

        .sidebar { width: 300px; background: rgba(0,0,0,0.3); border-right: 1px solid rgba(255,255,255,0.05); display: flex; flex-direction: column; }
        .search-box { padding: 10px; border-bottom: 1px solid rgba(255,255,255,0.05); }
        #search-in { width: 100%; background: #2a475e; border: none; padding: 8px; color: white; border-radius: 3px; font-size: 12px; }
        
        .game-list { flex: 1; overflow-y: auto; }
        .game-item { padding: 10px 20px; font-size: 13px; color: #8f98a0; cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .game-item:hover { background: rgba(255,255,255,0.05); color: white; }
        .game-item.active { background: linear-gradient(to right, #3d4450, transparent); color: white; }

        .main-view { flex: 1; overflow-y: auto; background: var(--steam-bg); position: relative; }
        .banner {
            width: 100%; height: 400px; background-size: cover; background-position: center;
            display: flex; flex-direction: column; justify-content: flex-end;
            padding: 40px; box-shadow: inset 0 -100px 80px var(--steam-bg);
        }

        .action-bar { padding: 25px 40px; background: rgba(0,0,0,0.3); display: flex; align-items: center; gap: 20px; }
        .btn { padding: 12px 35px; border-radius: 2px; border: none; cursor: pointer; font-weight: 800; text-transform: uppercase; color: white; }
        .btn-green { background: linear-gradient(to bottom, #a4d007 5%, #536904 95%); }
        .btn-blue { background: #66c0f4; }

        #cart-modal, #bio-modal {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(23, 29, 37, 0.98); display: none; z-index: 5000; padding: 50px;
        }

        #bio-modal { background: rgba(0,0,0,0.98); display: none; justify-content: center; align-items: center; flex-direction: column; }
        .scanner-box { width: 180px; height: 180px; border: 4px solid #222; border-radius: 50%; display: flex; justify-content: center; align-items: center; position: relative; cursor: pointer; }
        .scan-ring { position: absolute; width: 180px; height: 180px; border-radius: 50%; border: 4px solid transparent; border-top-color: var(--steam-blue); transition: 3s linear; }
        .scanning .scan-ring { transform: rotate(360deg); border-top-color: var(--steam-green); }
    </style>
</head>
<body oncontextmenu="return false;">

    <header>
        <div class="nav-link active" id="btn-store" onclick="showTab('store')">Mağaza</div>
        <div class="nav-link" id="btn-lib" onclick="showTab('lib')">Kütüphane</div>
        <div class="header-right">
            <div id="wallet-text" style="color:var(--steam-green)">Cüzdan: 20000 TL</div>
            <div class="cart-btn" onclick="openCart()">SEPET (<span id="cart-count">0</span>)</div>
        </div>
    </header>

    <div class="wrapper">
        <div class="sidebar">
            <div class="search-box"><input type="text" id="search-in" placeholder="Ara..." onkeyup="filterGames()"></div>
            <div class="game-list" id="list-container"></div>
        </div>
        <div class="main-view" id="content-area"></div>
    </div>

    <div id="cart-modal">
        <div style="max-width: 700px; margin: 0 auto;">
            <h1 style="margin-bottom:30px; font-weight: 300;">SEPETİNİZ</h1>
            <div id="cart-items"></div>
            <div style="text-align:right; margin-top:20px; border-top: 1px solid #333; padding-top: 20px;">
                <h2 id="total-price" style="margin-bottom:20px; color: var(--steam-blue);">0 TL</h2>
                <button class="btn btn-green" onclick="checkout()">Ödemeye Geç</button>
                <button class="btn" style="background:#444" onclick="closeCart()">Kapat</button>
            </div>
        </div>
    </div>

    <div id="bio-modal">
        <div class="scanner-box" id="scanner" onmousedown="startScan()" onmouseup="stopScan()" ontouchstart="startScan()" ontouchend="stopScan()">
            <div class="scan-ring"></div>
            <span style="font-size:70px">☝️</span>
        </div>
        <h2 style="margin-top:35px; letter-spacing:5px; font-weight: 900;">BİYOMETRİK ONAY</h2>
        <p style="color:#555; margin-top:15px; font-size: 13px;">SATIN ALMAK İÇİN BASILI TUTUN</p>
    </div>

    <script>
        let wallet = 20000;
        let cart = [];
        let myLibrary = [];
        let currentTab = 'store';
        let selectedId = 1245620;
        let scanTimer;

        // Gerçek Steam API Görselleri ile Oyunlar
        const realGames = [
            { id: 1245620, name: "Elden Ring", price: 999, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1245620/library_hero.jpg" },
            { id: 1174180, name: "Red Dead Redemption 2", price: 1150, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1174180/library_hero.jpg" },
            { id: 1091500, name: "Cyberpunk 2077", price: 799, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1091500/library_hero.jpg" },
            { id: 1086940, name: "Baldur's Gate 3", price: 799, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1086940/library_hero.jpg" },
            { id: 12240, name: "Grand Theft Auto: San Andreas", price: 350, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/12100/library_hero.jpg" },
            { id: 2358720, name: "Black Myth: Wukong", price: 1499, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2358720/library_hero.jpg" },
            { id: 271590, name: "Grand Theft Auto V", price: 550, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/271590/library_hero.jpg" },
            { id: 1593500, name: "God of War", price: 899, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1593500/library_hero.jpg" },
            { id: 730, name: "Counter-Strike 2", price: 0, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/730/library_hero.jpg" },
            { id: 292030, name: "The Witcher 3: Wild Hunt", price: 400, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/292030/library_hero.jpg" },
            { id: 413150, name: "Stardew Valley", price: 280, img: "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/413150/library_hero.jpg" }
        ];

        function showTab(tab) {
            currentTab = tab;
            document.getElementById('btn-store').classList.toggle('active', tab === 'store');
            document.getElementById('btn-lib').classList.toggle('active', tab === 'lib');
            renderList();
        }

        function renderList() {
            const container = document.getElementById('list-container');
            container.innerHTML = '';
            const data = currentTab === 'store' ? realGames : realGames.filter(g => myLibrary.includes(g.id));
            data.forEach(g => {
                const div = document.createElement('div');
                div.className = `game-item ${selectedId === g.id ? 'active' : ''}`;
                div.innerText = (myLibrary.includes(g.id) ? '● ' : '') + g.name;
                div.onclick = () => selectGame(g.id);
                container.appendChild(div);
            });
            if(data.length > 0 && !selectedId) selectGame(data[0].id);
        }

        function selectGame(id) {
            selectedId = id;
            const game = realGames.find(g => g.id === id);
            const owned = myLibrary.includes(id);
            const inCart = cart.includes(id);
            document.querySelectorAll('.game-item').forEach(el => el.classList.toggle('active', el.innerText.includes(game.name)));
            document.getElementById('content-area').innerHTML = `
                <div class="banner" style="background-image: url('${game.img}')">
                    <h1 style="text-shadow: 0 5px 20px black; font-size: 50px;">${game.name}</h1>
                </div>
                <div class="action-bar">
                    ${owned ? '<button class="btn btn-green">BAŞLAT</button>' : 
                      inCart ? '<button class="btn" style="background:#4c6b22" onclick="openCart()">SEPETTE</button>' :
                      `<button class="btn btn-blue" onclick="addToCart(${game.id})">SEPETE EKLE (${game.price} TL)</button>`}
                </div>
            `;
        }

        function addToCart(id) {
            if(!cart.includes(id)) { cart.push(id); document.getElementById('cart-count').innerText = cart.length; selectGame(id); }
        }

        function openCart() {
            const itemsDiv = document.getElementById('cart-items');
            itemsDiv.innerHTML = ''; let total = 0;
            cart.forEach(id => {
                const g = realGames.find(x => x.id === id); total += g.price;
                itemsDiv.innerHTML += `<div style="display:flex; justify-content:space-between; padding:15px; background:rgba(0,0,0,0.2); margin-bottom:5px;"><span>${g.name}</span><span>${g.price} TL</span></div>`;
            });
            document.getElementById('total-price').innerText = `Toplam: ${total} TL`;
            document.getElementById('cart-modal').style.display = 'block';
        }

        function closeCart() { document.getElementById('cart-modal').style.display = 'none'; }

        function checkout() {
            let total = 0; cart.forEach(id => total += realGames.find(x => x.id === id).price);
            if(wallet < total) return alert("Bakiye yetersiz!");
            document.getElementById('bio-modal').style.display = 'flex';
        }

        function startScan() {
            document.getElementById('scanner').parentElement.classList.add('scanning');
            scanTimer = setTimeout(() => {
                let total = 0; cart.forEach(id => { total += realGames.find(x => x.id === id).price; myLibrary.push(id); });
                wallet -= total; cart = [];
                document.getElementById('cart-count').innerText = "0";
                document.getElementById('wallet-text').innerText = `Cüzdan: ${wallet} TL`;
                document.getElementById('bio-modal').style.display = 'none';
                document.getElementById('cart-modal').style.display = 'none';
                alert("ÖDEME ONAYLANDI!"); renderList();
            }, 3000);
        }

        function stopScan() { clearTimeout(scanTimer); document.getElementById('scanner').parentElement.classList.remove('scanning'); }

        function filterGames() {
            const val = document.getElementById('search-in').value.toLowerCase();
            document.querySelectorAll('.game-item').forEach(it => it.style.display = it.innerText.toLowerCase().includes(val) ? 'block' : 'none');
        }

        showTab('store');
    </script>
</body>
</html>
